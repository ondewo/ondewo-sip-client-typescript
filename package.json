{
	"name": "@ondewo/sip-client-typescript",
	"version": "5.3.0",
	"description": "ONDEWO Session Initiation Protocol (SIP) Client library for Typescript",
	"author": "ONDEWO GmbH <office@ondewo.com>",
	"homepage": "https://ondewo.com",
	"license": "Apache-2.0",
	"keywords": [
		"ondewo",
		"sip",
		"api",
		"client",
		"typescript",
		"grpc"
	],
	"main": "public-api.js",
	"typings": "public-api.d.ts",
	"scripts": {
		"start": "npm run build",
		"build": "docker run -it -v ${PWD}:/input-volume -v ${PWD}/..:/output-volume ondewo-typescript-proto-compiler ondewo-sip-api ondewo",
		"predebug": "mv ondewo-sip-api/googleapis/google ondewo-sip-api/google",
		"debug": "docker run -it --entrypoint /bin/bash -v ${PWD}:/input-volume -v ${PWD}/..:/output-volume ondewo-typescript-proto-compiler",
		"pretest": "tsc auth/offlineTokenProvider.ts auth/offlineTokenProvider.spec.ts examples/ts-client.ts examples/ts-client.spec.ts --ignoreConfig --module commonjs --target es2020 --strict --lib es2020,dom --skipLibCheck --sourceMap --types node --typeRoots ./node_modules/@types --outDir .test-build && ln -sfn ../api .test-build/api",
		"test": "npm run test:auth && npm run test:examples",
		"test:auth": "c8 --check-coverage --lines 100 --branches 100 --functions 100 --include '**/offlineTokenProvider.js' --exclude '**/*.spec.js' --reporter text node --test .test-build/auth/offlineTokenProvider.spec.js",
		"test:examples": "c8 --check-coverage --lines 100 --branches 100 --functions 100 --include '**/ts-client.js' --exclude '**/*.spec.js' --reporter text node --test .test-build/examples/ts-client.spec.js"
	},
	"repository": {
		"type": "git",
		"directory": "https://github.com/ondewo/ondewo-sip-client-typescript"
	},
	"dependencies": {
		"google-protobuf": "3.21.4",
		"grpc-web": "^1.5.0",
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.1",
		"@eslint/js": "^9.36.0",
		"@types/node": "^22.15.27",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"c8": "^11.0.0",
		"dotenv": "^16.4.5",
		"eslint": "^9.36.0",
		"global": "^4.4.0",
		"husky": "^9.1.7",
		"prettier": "^3.6.2",
		"typescript": "^6.0.3"
	}
}
