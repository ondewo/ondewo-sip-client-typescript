# Configuration template for the ONDEWO SIP TypeScript client examples.
#
# This is a NON-SECRET template: copy it, fill in real values locally, and never commit secrets.
# Each example loads this file via dotenv (path resolved relative to the script, so the cwd does not
# matter). Uses the canonical ONDEWO env-var scheme shared across all ONDEWO client SDKs.

# --- Connection (gRPC-web endpoint of the SIP server / envoy proxy) ---
ONDEWO_HOST=localhost
ONDEWO_PORT=8080

# --- Secure channel ---
# true  -> connect over https (wss), false -> plain http
ONDEWO_USE_SECURE_CHANNEL=false

# --- Keycloak (D18 headless-SDK offline-token login) ---
KEYCLOAK_URL=https://auth.example.com/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
# 2FA-exempt technical-user credentials used for the ROPC login.
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Verify the Keycloak TLS certificate (set false only for a self-signed local Envoy).
KEYCLOAK_VERIFY_SSL=true

# --- SIP service-specific ---
# SIP account to start the session for.
ONDEWO_SIP_ACCOUNT_NAME=default
# Seconds before an incoming call is auto-answered (0 disables auto-answer).
ONDEWO_SIP_AUTO_ANSWER_INTERVAL=0
